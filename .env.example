#--------------------------------------------------------------------
# MenuScanOrder — local development environment
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed.
# Generate the encryption key with: php spark key:generate
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
# Force HTTPS in production; keep false for local http development.
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
encryption.key =

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = menuscanorder
database.default.username = root
database.default.password = root
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.DBDebug = true

# Test database (used by PHPUnit)
database.tests.hostname = localhost
database.tests.database = menuscanorder_test
database.tests.username = root
database.tests.password = root
database.tests.DBDriver = MySQLi
database.tests.port = 3306

#--------------------------------------------------------------------
# IMAGE STORAGE (Cloudflare R2)
#
# Leave these blank for local development — menu images then fall back
# to public/uploads/menu_items. Set all of them in production so images
# persist across redeploys.
#--------------------------------------------------------------------
# R2_ENDPOINT = 'https://<account-id>.r2.cloudflarestorage.com'
# R2_BUCKET = menuscanorder
# R2_ACCESS_KEY_ID =
# R2_SECRET_ACCESS_KEY =
# R2_PUBLIC_URL = 'https://<your-public-bucket-or-cdn-domain>'
